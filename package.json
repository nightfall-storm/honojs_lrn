{
  "name": "taskflows_learn",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "env:check": "bun -e 'import \"./src/env.ts\"'",
    "db:ping": "bun -e \"import { db } from './src/db'; await db.execute('SELECT 1'); console.log('Pinged!')\""
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.10.3",
    "@t3-oss/env-core": "^0.13.10",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0"
  }
}
